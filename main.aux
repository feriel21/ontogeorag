\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Effect of retrieval grounding on benchmark recall (left) and query productivity (right) across three configurations. \textbf  {Memory only}: the language model answers from parametric memory with no corpus access. \textbf  {LLM-BM25}: BM25 keyword retrieval only. \textbf  {LLM-Rerank}: BM25 retrieval followed by cross-encoder re-ranking. The dashed orange line on the left panel shows the corpus-gap corrected recall ceiling of 75.0\% (26 of 32 recoverable edges), which accounts for the two benchmark edges absent from the corpus. The silent query rate (right) measures the fraction of the 249 ontology-guided queries that produce no extracted triples; its decrease from 88.0\% to 39.4\% across configurations reflects the increasing ability of retrieval to surface relevant passages. Each percentage point gain in recall corresponds to one additional benchmark edge recovered.}}{20}{figure.caption.32}\protected@file@percent }
\newlabel{fig:retrieval-comparison}{{4}{20}{Effect of retrieval grounding on benchmark recall (left) and query productivity (right) across three configurations. \textbf {Memory only}: the language model answers from parametric memory with no corpus access. \textbf {LLM-BM25}: BM25 keyword retrieval only. \textbf {LLM-Rerank}: BM25 retrieval followed by cross-encoder re-ranking. The dashed orange line on the left panel shows the corpus-gap corrected recall ceiling of 75.0\% (26 of 32 recoverable edges), which accounts for the two benchmark edges absent from the corpus. The silent query rate (right) measures the fraction of the 249 ontology-guided queries that produce no extracted triples; its decrease from 88.0\% to 39.4\% across configurations reflects the increasing ability of retrieval to surface relevant passages. Each percentage point gain in recall corresponds to one additional benchmark edge recovered}{figure.caption.32}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Effect of retrieval on recall, comparing the memory-only experiment (no retrieval), BM25-only retrieval (LLM-BM25), and retrieval with re-ranking (LLM-Rerank). The silent query rate is the fraction of the 249 ontology-guided queries that produce no extracted triples before filtering.}}{21}{table.caption.33}\protected@file@percent }
\newlabel{tab:expb}{{7}{21}{Effect of retrieval on recall, comparing the memory-only experiment (no retrieval), BM25-only retrieval (LLM-BM25), and retrieval with re-ranking (LLM-Rerank). The silent query rate is the fraction of the 249 ontology-guided queries that produce no extracted triples before filtering}{table.caption.33}{}}
